# Copy to .env.deploy and set production secrets
# Database
DATABASE_URL="postgresql://user:pass@host:5432/db"

# Supabase
SUPABASE_URL=https://example.supabase.co
SUPABASE_KEY=replace

# Redis (used for both cache + queue; same VPS as app, reachable via VPS host IP)
REDIS_HOST=43.163.91.9
REDIS_PORT=6379
REDIS_PASSWORD=supersecret

# Queue Redis overrides (optional)
QUEUE_REDIS_HOST=43.163.91.9
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=supersecret
QUEUE_REDIS_DB=1

# API
PORT=3000
ENABLE_AUTH=true
BETTER_AUTH_SECRET=replace_with_openssl_rand_base64_32
BETTER_AUTH_URL=https://your-api.example.com
CORS_ORIGINS=https://your-frontend.example.com
ENABLE_TIERED_MUTATION_QUEUES=false
ENABLE_MUTATION_CONFLICT_GUARD=true
