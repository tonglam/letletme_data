# Database
DATABASE_URL="postgresql://[username]:[password]@[host]:[port]/[database]?pgbouncer=true&timezone=Asia/Hong_Kong"

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Redis
REDIS_HOST=redis.internal.example
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Queue Redis (optional, defaults to Redis settings)
QUEUE_REDIS_HOST=redis.internal.example
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=your_queue_redis_password
QUEUE_REDIS_DB=1

PORT=3000
ENABLE_AUTH=false
# Comma-separated SHA-256 digests of internal service API keys.
# Generate a key with `openssl rand -base64 32`, then hash it with:
# `printf %s "$KEY" | shasum -a 256`
DATA_API_KEY_HASHES=
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# HTTP mutation rate limit per client IP (fixed 1-minute window; 0 disables)
RATE_LIMIT_MUTATIONS_PER_MINUTE=60
ENABLE_TIERED_MUTATION_QUEUES=false
ENABLE_MUTATION_CONFLICT_GUARD=true
# Keep `latest` until migration 0034 from the transfer cutover PR is applied.
TRANSFER_SYNC_MODE=latest
# Optional tuning:
# MUTATION_LOCK_TTL_MS=30000
# MUTATION_LOCK_WAIT_TIMEOUT_MS=120000
# MUTATION_LOCK_RETRY_DELAY_MS=250
# MUTATION_LOCK_HEARTBEAT_MS=10000

# Telegram direct bot API notifications (optional, used by src/utils/notify.ts sendTelegramMessage)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
